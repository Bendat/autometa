{
  "compileOnSave": false,
  "references": [
    { "path": "./packages/libs/logging" },
    { "path": "./packages/utils/libs" },
    { "path": "./packages/utils/logging" },
    { "path": "./packages/utils/dependency-injection" }
  ],
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "esnext",
    "lib": ["es2022"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@automaton/cucumber-integration-tests": [
        "packages/bdd/cucumber-integration-tests/src/index.ts"
      ],
      "@automaton/cucumber": ["packages/bdd/cucumber/src/index.ts"],
      "@automaton/dependency-injection": [
        "packages/utils/dependency-injection/src/index.ts"
      ],
      "@automaton/dto-builder": ["packages/libs/dto-builder/src/index.ts"],
      "@automaton/logging": ["packages/libs/logging/src/index.ts"],
      "@automaton/page-components": [
        "packages/page-object-models/page-components/src/index.ts"
      ],
      "@automaton/page-object-models/page-components-tests": [
        "packages/page-object-models/page-components-tests/src/index.ts"
      ],
      "@automaton/shared-utilities": [
        "packages/utils/shared-utilities/src/index.ts"
      ],
      "@automaton/store": ["packages/utils/store/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"],
  "include": ["src"]
}
