{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/page-components-model/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/page-components-model",
        "main": "packages/page-components-model/src/index.ts",
        "tsConfig": "packages/page-components-model/tsconfig.lib.json",
        "assets": ["packages/page-components-model/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/page-components-model/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/packages/page-components-model"],
      "options": {
        "jestConfig": "packages/page-components-model/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
