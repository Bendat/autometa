{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/utils/logging/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["packages/utils/logging/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/packages/utils/logging"],
      "options": {
        "jestConfig": "packages/utils/logging/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "build": {
      "executor": "@nrwl/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/utils/logging",
        "tsConfig": "packages/utils/logging/tsconfig.lib.json",
        "packageJson": "packages/utils/logging/package.json",
        "main": "packages/utils/logging/src/index.ts",
        "assets": ["packages/utils/logging/*.md"]
      }
    }
  },
  "tags": ["scope:public", "type:util", "target:all"]
}
